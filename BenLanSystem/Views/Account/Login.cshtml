@model BenLanSystem.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<section class="auth-shell">
    <div class="auth-stage">
        <p class="auth-page-title">Log in page</p>

        <div class="auth-frame">
            <div class="auth-photo-wrap">
                <img src="~/designs/login/loginAndRegister.png" alt="Travelers enjoying a trip" class="auth-photo" />
            </div>

            <div class="auth-card">
                <img src="~/designs/image.png" alt="BenLan logo" class="auth-logo" />

                <div class="auth-header">
                    <h1>Before enjoy your trip</h1>
                    <p class="auth-subtitle">Please Sign in</p>
                </div>

                <form asp-action="Login" asp-controller="Account" method="post" class="auth-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                    <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

                    <div class="auth-field">
                        <label asp-for="Email">Username / Email</label>
                        <input asp-for="Email" class="auth-input" placeholder="Please enter your email" />
                        <span asp-validation-for="Email" class="auth-error"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Password"></label>
                        <input asp-for="Password" class="auth-input" placeholder="Please enter your password" />
                        <span asp-validation-for="Password" class="auth-error"></span>
                    </div>

                    <a href="#" class="auth-forgot">Forget password?</a>

                    <button type="submit" class="auth-submit">Log in</button>
                </form>

                <p class="auth-alt-link">
                    Don't have an account?
                    <a asp-action="Register" asp-controller="Account">Register</a>
                </p>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
