@model BenLanSystem.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<section class="auth-shell">
    <div class="auth-card">
        <div class="auth-header">
            <p class="auth-overline">Get started</p>
            <h1>Create your account</h1>
            <p class="auth-subtitle">Book faster, track your trips, and keep every ticket in one place.</p>
        </div>

        <form asp-action="Register" asp-controller="Account" method="post" class="auth-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

            <div class="auth-field">
                <label asp-for="FullName"></label>
                <input asp-for="FullName" class="auth-input" placeholder="Your full name" />
                <span asp-validation-for="FullName" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="auth-input" placeholder="name@example.com" />
                <span asp-validation-for="Email" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Password"></label>
                <input asp-for="Password" class="auth-input" placeholder="At least 6 characters" />
                <span asp-validation-for="Password" class="auth-error"></span>
            </div>

            <div class="auth-field">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="auth-input" placeholder="Repeat your password" />
                <span asp-validation-for="ConfirmPassword" class="auth-error"></span>
            </div>

            <button type="submit" class="auth-submit">Create account</button>
        </form>

        <p class="auth-alt-link">
            Already have an account?
            <a asp-action="Login" asp-controller="Account">Login</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
