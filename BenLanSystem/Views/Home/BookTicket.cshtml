@{
    ViewData["Title"] = "Book Ticket";
    ViewData["ActivePage"] = "Book";
    ViewData["Description"] = "Search and book your bus tickets easily with BenLan.";
}

@section Styles {
    <link rel="stylesheet" href="~/css/bookticket.css" asp-append-version="true"/>
}

<!-- =============================================
     HERO / SEARCH SECTION
     ============================================= -->
<section class="bt-hero">
    <div class="bt-hero-img-wrap">
        <img src="~/designs/hero.png" alt="BenLan Bus" class="bt-hero-img" />
        <div class="bt-hero-overlay"></div>
    </div>

    <!-- Search Bar -->
    <div class="bt-search-bar" id="bt-search-bar">
        <!-- Departing From -->
        <div class="bt-field" id="bt-field-from">
            <span class="bt-field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 2L11 13"/><path d="M22 2L15 22L11 13L2 9L22 2Z"/>
                </svg>
            </span>
            <input type="text" placeholder="Departing from" id="bt-input-from" autocomplete="off" />
        </div>

        <!-- Swap button -->
        <button class="bt-swap-btn" id="bt-swap-btn" type="button" title="Swap">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 16V4m0 0L3 8m4-4l4 4"/><path d="M17 8v12m0 0l4-4m-4 4l-4-4"/>
            </svg>
        </button>

        <!-- Going To -->
        <div class="bt-field" id="bt-field-to">
            <span class="bt-field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
            </span>
            <input type="text" placeholder="Going to" id="bt-input-to" autocomplete="off" />
        </div>

        <!-- Divider -->
        <div class="bt-field-divider"></div>

        <!-- Going Date -->
        <div class="bt-field" id="bt-field-date">
            <span class="bt-field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </span>
            <input type="text" placeholder="Going date" id="bt-input-date"
                   onfocus="(this.type='date')" onblur="if(!this.value)(this.type='text')" />
        </div>

        <!-- Return Date -->
        <div class="bt-field" id="bt-field-return">
            <span class="bt-field-icon">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
            </span>
            <input type="text" placeholder="Returning date" id="bt-input-return"
                   onfocus="(this.type='date')" onblur="if(!this.value)(this.type='text')" />
        </div>

        <!-- Search -->
        <button class="bt-search-btn" id="bt-search-btn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            Search
        </button>
    </div>
</section>

<!-- =============================================
     RESULTS SECTION
     ============================================= -->
<section class="bt-results-section">
    <div class="bt-results-inner">

        <!-- Sort / Filter Bar -->
        <div class="bt-filter-bar">
            <span class="bt-results-count" id="bt-results-count">Showing <strong>3</strong> results</span>
            <div class="bt-sort-group">
                <label class="bt-sort-label">Sort by:</label>
                <select class="bt-sort-select" id="bt-sort-select">
                    <option value="departure">Departure time</option>
                    <option value="price-asc">Price: Low to High</option>
                    <option value="price-desc">Price: High to Low</option>
                    <option value="duration">Duration</option>
                </select>
            </div>
        </div>

        <!-- Ticket List -->
        <div class="bt-ticket-list" id="bt-ticket-list">

            <!-- Ticket 1 -->
            <div class="bt-ticket" id="bt-ticket-1">
                <div class="bt-ticket-seats" id="bt-ticket-1-seats">9/12 Seats</div>

                <div class="bt-ticket-left">
                    <div class="bt-van-img-wrap">
                        <img src="~/designs/bmc.png" alt="Luxury Van" class="bt-van-img" />
                    </div>
                    <div class="bt-operator">
                        <img src="~/designs/image.png" alt="BenLan" class="bt-operator-logo" />
                        <div class="bt-operator-info">
                            <span class="bt-operator-name">Luxury Van (12)</span>
                            <span class="bt-operator-route">Direct · Road N63</span>
                        </div>
                    </div>
                </div>

                <div class="bt-ticket-times">
                    <div class="bt-time-col">
                        <span class="bt-time-label">Departure</span>
                        <span class="bt-time-value">14:45</span>
                    </div>
                    <div class="bt-duration-col">
                        <span class="bt-time-label">Duration</span>
                        <div class="bt-duration-display">
                            <div class="bt-duration-line"></div>
                            <span class="bt-time-value">4:00h</span>
                            <div class="bt-duration-line"></div>
                        </div>
                    </div>
                    <div class="bt-time-col">
                        <span class="bt-time-label">Arrival</span>
                        <span class="bt-time-value">18:45</span>
                    </div>
                </div>

                <div class="bt-ticket-right">
                    <span class="bt-price">$14.5</span>
                    <button class="bt-book-btn" onclick="openBookingModal('Phnom Penh', 'Siem Reap', '14:45', '18:45', '$14.5')">Book now</button>
                </div>
            </div>

            <!-- Ticket 2 -->
            <div class="bt-ticket" id="bt-ticket-2">
                <div class="bt-ticket-seats" id="bt-ticket-2-seats">6/12 Seats</div>

                <div class="bt-ticket-left">
                    <div class="bt-van-img-wrap">
                        <img src="~/designs/btb.png" alt="Luxury Van" class="bt-van-img" />
                    </div>
                    <div class="bt-operator">
                        <img src="~/designs/image.png" alt="BenLan" class="bt-operator-logo" />
                        <div class="bt-operator-info">
                            <span class="bt-operator-name">Luxury Van (12)</span>
                            <span class="bt-operator-route">Direct · Road N6</span>
                        </div>
                    </div>
                </div>

                <div class="bt-ticket-times">
                    <div class="bt-time-col">
                        <span class="bt-time-label">Departure</span>
                        <span class="bt-time-value">08:00</span>
                    </div>
                    <div class="bt-duration-col">
                        <span class="bt-time-label">Duration</span>
                        <div class="bt-duration-display">
                            <div class="bt-duration-line"></div>
                            <span class="bt-time-value">5:30h</span>
                            <div class="bt-duration-line"></div>
                        </div>
                    </div>
                    <div class="bt-time-col">
                        <span class="bt-time-label">Arrival</span>
                        <span class="bt-time-value">13:30</span>
                    </div>
                </div>

                <div class="bt-ticket-right">
                    <span class="bt-price">$12.0</span>
                    <button class="bt-book-btn" onclick="openBookingModal('Phnom Penh', 'Siem Reap', '08:00', '13:30', '$12.0')">Book now</button>
                </div>
            </div>

            <!-- Ticket 3 -->
            <div class="bt-ticket" id="bt-ticket-3">
                <div class="bt-ticket-seats" id="bt-ticket-3-seats">11/12 Seats</div>

                <div class="bt-ticket-left">
                    <div class="bt-van-img-wrap">
                        <img src="~/designs/bmc.png" alt="Luxury Van" class="bt-van-img" />
                    </div>
                    <div class="bt-operator">
                        <img src="~/designs/image.png" alt="BenLan" class="bt-operator-logo" />
                        <div class="bt-operator-info">
                            <span class="bt-operator-name">Luxury Van (12)</span>
                            <span class="bt-operator-route">1 Stop · Road N5</span>
                        </div>
                    </div>
                </div>

                <div class="bt-ticket-times">
                    <div class="bt-time-col">
                        <span class="bt-time-label">Departure</span>
                        <span class="bt-time-value">06:30</span>
                    </div>
                    <div class="bt-duration-col">
                        <span class="bt-time-label">Duration</span>
                        <div class="bt-duration-display">
                            <div class="bt-duration-line"></div>
                            <span class="bt-time-value">3:30h</span>
                            <div class="bt-duration-line"></div>
                        </div>
                    </div>
                    <div class="bt-time-col">
                        <span class="bt-time-label">Arrival</span>
                        <span class="bt-time-value">10:00</span>
                    </div>
                </div>

                <div class="bt-ticket-right">
                    <span class="bt-price">$10.0</span>
                    <button class="bt-book-btn" onclick="openBookingModal('Phnom Penh', 'Kampot', '06:30', '10:00', '$10.0')">Book now</button>
                </div>
            </div>

        </div><!-- end bt-ticket-list -->
    </div>
</section>

<!-- =============================================
     BOOKING MODAL
     ============================================= -->
<div class="bt-modal-backdrop" id="bt-modal-backdrop" onclick="closeBookingModal()"></div>
<div class="bt-modal" id="bt-modal" role="dialog" aria-modal="true" aria-labelledby="bt-modal-title">
    <div class="bt-modal-header">
        <h3 class="bt-modal-title" id="bt-modal-title">Confirm Booking</h3>
        <button class="bt-modal-close" onclick="closeBookingModal()" aria-label="Close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
        </button>
    </div>

    <div class="bt-modal-body">
        <!-- Route summary -->
        <div class="bt-modal-route">
            <div class="bt-modal-city" id="bt-modal-from">Phnom Penh</div>
            <div class="bt-modal-arrow">
                <svg width="32" height="16" viewBox="0 0 32 16" fill="none">
                    <path d="M1 8h28M22 2l8 6-8 6" stroke="rgba(255,255,255,0.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div class="bt-modal-city" id="bt-modal-to">Siem Reap</div>
        </div>

        <!-- Trip details -->
        <div class="bt-modal-details">
            <div class="bt-modal-detail-item">
                <span class="bt-modal-detail-label">Departure</span>
                <span class="bt-modal-detail-value" id="bt-modal-dep">14:45</span>
            </div>
            <div class="bt-modal-detail-item">
                <span class="bt-modal-detail-label">Arrival</span>
                <span class="bt-modal-detail-value" id="bt-modal-arr">18:45</span>
            </div>
            <div class="bt-modal-detail-item">
                <span class="bt-modal-detail-label">Price</span>
                <span class="bt-modal-detail-value bt-modal-price" id="bt-modal-price">$14.5</span>
            </div>
        </div>

        <!-- Passenger form -->
        <div class="bt-modal-form">
            <div class="bt-modal-field-row">
                <div class="bt-modal-field">
                    <label>First Name</label>
                    <input type="text" placeholder="Sopanha" id="bt-modal-firstname" />
                </div>
                <div class="bt-modal-field">
                    <label>Last Name</label>
                    <input type="text" placeholder="Soo" id="bt-modal-lastname" />
                </div>
            </div>
            <div class="bt-modal-field">
                <label>Phone Number</label>
                <input type="tel" placeholder="012 345 678" id="bt-modal-phone" />
            </div>
            <div class="bt-modal-field">
                <label>Number of Seats</label>
                <div class="bt-seat-picker">
                    <button type="button" class="bt-seat-btn" onclick="changeSeat(-1)">−</button>
                    <span class="bt-seat-count" id="bt-seat-count">1</span>
                    <button type="button" class="bt-seat-btn" onclick="changeSeat(1)">+</button>
                </div>
            </div>
        </div>
    </div>

    <div class="bt-modal-footer">
        <button class="bt-modal-cancel" onclick="closeBookingModal()">Cancel</button>
        <button class="bt-modal-confirm" id="bt-modal-confirm-btn" onclick="confirmBooking()">
            Confirm Booking
        </button>
    </div>
</div>

@section Scripts {
    <script src="~/js/bookticket.js" asp-append-version="true"></script>
}
