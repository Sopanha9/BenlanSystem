@{
    ViewData["Title"] = "About Us";
    ViewData["Description"] = "Learn about BenLan — Cambodia's modern transportation management platform connecting you to destinations safely and comfortably.";
    ViewData["ActivePage"] = "About";
}

@section Styles {
    <link rel="stylesheet" href="~/css/about.css" asp-append-version="true"/>
}

<!-- =============================================
     ABOUT US PAGE
     ============================================= -->

<!-- ── Section 1: Hero split (image left / text right) ── -->
<section class="about-hero-section" id="about-hero">
    <div class="about-hero-inner">

        <!-- Left: Angkor image -->
        <div class="about-hero-img-wrap" id="about-hero-img">
            <img src="~/designs/aboutus/angkor.png" alt="Angkor Wat at sunset" class="about-hero-img" />
        </div>

        <!-- Right: Text -->
        <div class="about-hero-text" id="about-hero-text">
            <h1 class="about-hero-title">ABOUT BENLAN Management</h1>
            <p class="about-hero-desc">
                Benlan Car Booking System is a modern transportation management platform designed to make travel easier and more convenient.
                Our system allows customers to book vehicles quickly and securely for trips to their desired destinations.
            </p>
            <p class="about-hero-desc">
                We focus on providing a smooth booking experience, reliable transportation services, and efficient trip management.
                The system helps manage customers, bookings, drivers, schedules, and payments in one centralized platform.
            </p>
        </div>

    </div>
</section>

<!-- ── Section 2: Why Choose Us card ── -->
<section class="about-why-section" id="about-why">
    <div class="about-section-container">
        <div class="about-why-card" id="about-why-card">

            <!-- Left: text -->
            <div class="about-why-text" id="about-why-text">
                <h2 class="about-why-title">Why Choose Us</h2>
                <p class="about-why-desc">
                    We offer a fast and simple booking process that makes planning your trip quick and hassle-free.
                    Your journey is designed with safety and comfort in mind, ensuring a smooth and enjoyable travel experience every time.
                    Our professional drivers are well-trained, reliable, and committed to providing excellent service throughout your trip.
                    With transparent pricing, you'll always know exactly what you're paying for — no hidden fees or surprises.
                    Behind the scenes, our efficient system management ensures everything runs on schedule so you can travel with confidence.
                </p>
            </div>

            <!-- Right: bus image -->
            <div class="about-why-img-wrap" id="about-why-img">
                <img src="~/designs/aboutus/car.png" alt="BenLan luxury bus" class="about-why-img" />
            </div>

        </div>
    </div>
</section>

<!-- ── Section 3: Two "What Our System Provides" cards ── -->
<section class="about-provides-section" id="about-provides">
    <div class="about-section-container">
        <div class="about-provides-grid" id="about-provides-grid">

            <!-- Card 1 -->
            <div class="about-provides-card" id="about-provides-card-1">
                <h3 class="about-provides-title">What Our System Provides</h3>
                <p class="about-provides-desc">
                    We connect people to destinations with ease, ensuring every journey is smooth and comfortable.
                    Our service is designed to provide a relaxing travel experience, giving you the comfort you deserve along the way.
                    With us, you have the freedom to travel on your own terms, wherever and whenever you choose.
                </p>
            </div>

            <!-- Card 2 -->
            <div class="about-provides-card" id="about-provides-card-2">
                <h3 class="about-provides-title">What Our System Provides</h3>
                <p class="about-provides-desc">
                    Our platform offers easy online car booking, allowing you to reserve your ride quickly and conveniently.
                    It also supports efficient trip and destination management, helping you plan your journey with ease.
                    With organized driver and vehicle management, we ensure reliable service and well-maintained transportation.
                    Our secure payment processing keeps your transactions safe and hassle-free.
                    You can access your booking history and reports anytime for better tracking, while real-time booking status keeps you updated every step of the way.
                </p>
            </div>

        </div>
    </div>
</section>

<!-- ── Section 4: Full-width landscape image ── -->
<section class="about-landscape-section" id="about-landscape">
    <img src="~/designs/aboutus/jrut.png" alt="Cambodia countryside" class="about-landscape-img" />
</section>

<!-- ── Section 5: Centered recap text block ── -->
<section class="about-recap-section" id="about-recap">
    <div class="about-section-container">
        <div class="about-recap-inner">
            <h2 class="about-recap-title">ABOUT BENLAN Management</h2>
            <p class="about-recap-desc">
                Benlan Car Booking System is a modern transportation management platform designed to make travel easier and more convenient.
                Our system allows customers to book vehicles quickly and securely for trips to their desired destinations.
                We focus on providing a smooth booking experience, reliable transportation services, and efficient trip management.
                The system helps manage customers, bookings, drivers, schedules, and payments in one centralized platform.
            </p>
        </div>
    </div>
</section>
