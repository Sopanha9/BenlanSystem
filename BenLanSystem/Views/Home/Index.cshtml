@{
    ViewData["Title"] = "Home Page";
    ViewData["ActivePage"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true"/>
}

<!-- Hero Section -->
<section class="hero-section" id="hero-section">
    <div class="hero-container">
        <!-- Hero Image with Glow Border -->
        <div class="hero-image-wrapper" id="hero-image-wrapper">
            <img src="~/designs/hero.png" alt="Angkor Wat Temple - Cambodia" class="hero-image" id="hero-image" />
        </div>

        <!-- Booking Form Card -->
        <div class="booking-card" id="booking-card">
            <h2 class="booking-title" id="booking-title">Book your ticket</h2>

            <form class="booking-form" id="booking-form">
                <!-- Departing From -->
                <div class="form-field" id="field-departing">
                    <input type="text" placeholder="Departing from" id="input-departing" autocomplete="off" />
                    <span class="field-icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M22 2L11 13"/>
                            <path d="M22 2L15 22L11 13L2 9L22 2Z"/>
                        </svg>
                    </span>
                </div>

                <!-- Going To -->
                <div class="form-field" id="field-goingto">
                    <input type="text" placeholder="Going to" id="input-goingto" autocomplete="off" />
                    <span class="field-icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                            <circle cx="12" cy="10" r="3"/>
                        </svg>
                    </span>
                </div>

                <!-- Going Date -->
                <div class="form-field" id="field-goingdate">
                    <input type="text" placeholder="Going date" id="input-goingdate" onfocus="(this.type='date')" onblur="if(!this.value)(this.type='text')" />
                    <span class="field-icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                    </span>
                </div>

                <!-- Returning Date -->
                <div class="form-field" id="field-returningdate">
                    <input type="text" placeholder="Returning date" id="input-returningdate" onfocus="(this.type='date')" onblur="if(!this.value)(this.type='text')" />
                    <span class="field-icon" aria-hidden="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                            <line x1="16" y1="2" x2="16" y2="6"/>
                            <line x1="8" y1="2" x2="8" y2="6"/>
                            <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                    </span>
                </div>

                <!-- Search Button -->
                <button type="submit" class="search-btn" id="search-button">Search</button>
            </form>
        </div>
    </div>
</section>

