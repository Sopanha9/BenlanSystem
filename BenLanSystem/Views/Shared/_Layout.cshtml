<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - BenLan</title>
    <meta name="description" content="@(ViewData["Description"] ?? "BenLan - Book your travel tickets easily. Explore Cambodia and beyond with our convenient booking system.")"/>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/BenLanSystem.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar -->
    <header>
        <nav class="benlan-navbar" id="main-navbar">
            <div class="navbar-inner">
                <a class="navbar-logo" asp-area="" asp-controller="Home" asp-action="Index" id="navbar-logo">
                    <img src="~/designs/image.png" alt="BenLan Logo" />
                </a>
                <ul class="navbar-links" id="navbar-links">
                    <li><a asp-controller="Home" asp-action="Index"   class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Home"    ? "active" : "")" id="nav-home">Home</a></li>
                    <li><a asp-controller="Home" asp-action="About"   class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "About"   ? "active" : "")" id="nav-about">About us</a></li>
                    <li><a href="#"                                    class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Book"    ? "active" : "")" id="nav-book">Book ticket</a></li>
                    <li><a asp-controller="Home" asp-action="Blog"    class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Blog"    ? "active" : "")" id="nav-blog">Blog</a></li>
                    <li><a asp-controller="Home" asp-action="Contact" class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Contact" ? "active" : "")" id="nav-contact">Contact</a></li>
                    <li><a href="#"                                    class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Booking" ? "active" : "")" id="nav-mybooking">My booking</a></li>
                </ul>
                <div class="navbar-profile" id="navbar-profile">
                    <button class="profile-btn" id="profile-button" aria-label="User profile">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                        </svg>
                    </button>
                </div>
                <!-- Mobile hamburger -->
                <button class="navbar-hamburger" id="navbar-hamburger" aria-label="Toggle menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    @await Html.PartialAsync("_Footer")

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>