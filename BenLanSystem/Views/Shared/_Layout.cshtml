<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - BenLan</title>
    <meta name="description" content="@(ViewData["Description"] ?? "BenLan - Book your travel tickets easily. Explore Cambodia and beyond with our convenient booking system.")"/>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/BenLanSystem.styles.css" asp-append-version="true"/>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var displayName = User?.Identity?.Name ?? "User";
        var profileInitial = displayName.Length > 0 ? char.ToUpperInvariant(displayName[0]).ToString() : "U";
    }
    <!-- Navbar -->
    <header>
        <nav class="benlan-navbar" id="main-navbar">
            <div class="navbar-inner">
                <a class="navbar-logo" asp-area="" asp-controller="Home" asp-action="Index" id="navbar-logo">
                    <img src="~/designs/image.png" alt="BenLan Logo" />
                </a>
                <ul class="navbar-links" id="navbar-links">
                    <li><a asp-controller="Home" asp-action="Index"   class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Home"    ? "active" : "")" id="nav-home">Home</a></li>
                    <li><a asp-controller="Home" asp-action="About"   class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "About"   ? "active" : "")" id="nav-about">About us</a></li>
                    <li><a asp-controller="Home" asp-action="BookTicket" class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Book" ? "active" : "")" id="nav-book">Book ticket</a></li>
                    <li><a asp-controller="Home" asp-action="Blog"    class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Blog"    ? "active" : "")" id="nav-blog">Blog</a></li>
                    <li><a asp-controller="Home" asp-action="Contact" class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Contact" ? "active" : "")" id="nav-contact">Contact</a></li>
                    <li><a href="#"                                    class="nav-link-item @(ViewData["ActivePage"]?.ToString() == "Booking" ? "active" : "")" id="nav-mybooking">My booking</a></li>
                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <li class="auth-nav-item"><a asp-controller="Account" asp-action="Login" class="nav-link-item" id="nav-login">Login</a></li>
                        <li class="auth-nav-item"><a asp-controller="Account" asp-action="Register" class="nav-link-item" id="nav-register">Register</a></li>
                    }
                </ul>
                <div class="navbar-profile" id="navbar-profile">
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <div class="auth-badge" id="profile-button" aria-label="User profile">@profileInitial</div>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="auth-link-btn">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="auth-link-btn auth-link-ghost">Login</a>
                        <a asp-controller="Account" asp-action="Register" class="auth-link-btn auth-link-solid">Register</a>
                    }
                </div>
                <!-- Mobile hamburger -->
                <button class="navbar-hamburger" id="navbar-hamburger" aria-label="Toggle menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    @await Html.PartialAsync("_Footer")

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>